# Google Cloud Project Configuration
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# Cloud Storage Buckets
UPLOADS_BUCKET=your-gcp-project-id-uploads
ASSETS_BUCKET=your-gcp-project-id-assets
TEMP_BUCKET=your-gcp-project-id-temp

# Firestore
FIRESTORE_DATABASE=(default)

# Pub/Sub
PUBSUB_TOPIC=content-generation-jobs
PUBSUB_SUBSCRIPTION=content-generation-jobs-sub

# Google GenAI SDK (optional — only needed for local development outside GCP)
# In production on Cloud Run, ADC via service account is used automatically.
# GEMINI_API_KEY=your-gemini-api-key

# Server
PORT=8080
