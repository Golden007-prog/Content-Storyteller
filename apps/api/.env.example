# Google Cloud Project Configuration
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# Cloud Storage Buckets
UPLOADS_BUCKET=your-gcp-project-id-uploads
ASSETS_BUCKET=your-gcp-project-id-assets

# Firestore
FIRESTORE_DATABASE=(default)

# Pub/Sub
PUBSUB_TOPIC=content-generation-jobs

# CORS — allowed origin for the Web App
# Use * for development. In production, set to your GitHub Pages URL.
# Supports comma-separated origins: https://user.github.io,http://localhost:5173
CORS_ORIGIN=*

# Server
PORT=8080

# Gemini API Key (optional — uses ADC via Vertex AI when not set)
GEMINI_API_KEY=

# Vertex AI Model Router (optional overrides — defaults are used if not set)
# VERTEX_TEXT_MODEL=gemini-3.1-flash
# VERTEX_TEXT_FALLBACK_MODEL=gemini-3-flash-preview
# VERTEX_REASONING_MODEL=gemini-3.1-pro-preview
# VERTEX_IMAGE_MODEL=gemini-3.1-flash-image-preview
# VERTEX_IMAGE_HQ_MODEL=gemini-3-pro-image-preview
# VERTEX_VIDEO_FAST_MODEL=veo-3.1-fast-generate-001
# VERTEX_VIDEO_FINAL_MODEL=veo-3.1-generate-001
# VERTEX_LIVE_MODEL=gemini-live-2.5-flash-native-audio
