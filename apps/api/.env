# Google Cloud Project Configuration
GCP_PROJECT_ID=deep-hook-468814-t7
GCP_REGION=us-central1

# Cloud Storage Buckets
UPLOADS_BUCKET=deep-hook-468814-t7-uploads
ASSETS_BUCKET=deep-hook-468814-t7-assets

# Firestore
FIRESTORE_DATABASE=(default)

# Pub/Sub
PUBSUB_TOPIC=content-generation-jobs

# CORS — allowed origin for the Web App
CORS_ORIGIN=*

# Gemini API Key (optional — uses ADC via Vertex AI when not set)
GEMINI_API_KEY=

# Vertex AI Model Overrides (use models available in this project)
VERTEX_TEXT_MODEL=gemini-2.5-flash
VERTEX_TEXT_FALLBACK_MODEL=gemini-2.5-flash
VERTEX_REASONING_MODEL=gemini-2.5-pro
VERTEX_IMAGE_MODEL=gemini-2.5-flash
VERTEX_IMAGE_HQ_MODEL=gemini-2.5-pro
VERTEX_TEXT_LOCATION=us-central1
VERTEX_TEXT_FALLBACK_LOCATION=us-central1
VERTEX_REASONING_LOCATION=us-central1
VERTEX_IMAGE_LOCATION=us-central1
VERTEX_IMAGE_HQ_LOCATION=us-central1

# Server
PORT=8080