{
  "name": "@content-storyteller/worker",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch --env-file=.env src/index.ts",
    "test": "vitest --run",
    "test:properties": "vitest --run --grep 'Property'",
    "test:coverage": "vitest --run --coverage"
  },
  "dependencies": {
    "@content-storyteller/shared": "*",
    "@google-cloud/firestore": "^7.11.0",
    "@google-cloud/storage": "^7.15.0",
    "@google-cloud/vertexai": "^1.10.0",
    "@google/genai": "^1.0.0",
    "express": "^4.21.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/pg": "^8.18.0",
    "fast-check": "^3.19.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
