# API base URL — leave empty for local development (Vite proxy handles it)
# Set to the full API URL in production (e.g. https://api-service-xxxxx-uc.a.run.app)
VITE_API_URL=

# Base path for GitHub Pages deployment (e.g. /content-storyteller/)
# Leave empty or '/' for local dev or root-domain hosting
VITE_BASE_PATH=/

# Server port (used by nginx in production)
PORT=3000
